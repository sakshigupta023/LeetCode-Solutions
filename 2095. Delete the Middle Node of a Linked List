/*
LeetCode 2095 - Delete the Middle Node of a Linked List

Approach:
- Use Slow and Fast Pointers to find the middle node.
- Maintain a prev pointer to track the node before slow.
- When slow reaches the middle, delete it by linking
  prev.next to slow.next.

Time Complexity: O(n)
Space Complexity: O(1)
*/

solution:- 

class Solution {
    public ListNode deleteMiddle(ListNode head) {

        if (head == null || head.next == null) {
            return null;
        }

        ListNode slow = head;
        ListNode fast = head;
        ListNode prev = null;

        while (fast != null && fast.next != null) {
            prev = slow;
            slow = slow.next;
            fast = fast.next.next;
        }

        prev.next = slow.next;

        return head;
    }
}
